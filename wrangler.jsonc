{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Cloudflare Workers config for the Lumi Derm static site.
  // Serves the contents of ./lumi-derm-website as static assets at the site root.
  "name": "lumiderm",
  "compatibility_date": "2026-06-28",
  "assets": {
    "directory": "./lumi-derm-website",
    "not_found_handling": "404-page"
  }
}
